generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Client {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  accountNumber String
  balance       Float    @default(0)
  status        String   @default("active")
  createdAt     DateTime @default(now())
}